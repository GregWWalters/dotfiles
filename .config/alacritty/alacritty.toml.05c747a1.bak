
[cursor]
vi_mode_style = "Block"

[cursor.style]
shape = "Block"

[env]
TERM_BG = "dark"
TERM_BG_DARK = "true"

[window]
# builtin_box_drawing = true
# columns = 100
# lines = 40
# size = 10.0
decorations = "none"
dynamic_title = true
opacity = 1.0
resize_increments = true
startup_mode = "Windowed"

[colors]
draw_bold_text_with_bright_colors = true
